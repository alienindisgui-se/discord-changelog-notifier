# ========================================
# FOR LOCAL DEVELOPMENT ONLY
# ========================================
# Copy this file to .env and fill in values for local testing

# Required for local testing
GITHUB_TOKEN="ghp_your_github_personal_access_token"
TEST_MODE="pr"
TEST_REPO="your-repo-name"
TEST_PR_NUMBER="1"

# Optional for local testing
DISCORD_WEBHOOK="https://discord.com/api/webhooks/your_webhook_url"
GEMINI_API_KEY="your_google_gemini_api_key"
GROQ_API_KEY="gsk_your_groq_api_key"
LANGUAGE="sv"
LOG_DIR="logs"

# ========================================
# FOR GITHUB ACTIONS (PRODUCTION)
# ========================================
# The action automatically uses these from the workflow:
# - GITHUB_TOKEN (provided by GitHub Actions)
# - GITHUB_EVENT_PATH (provided by GitHub Actions)
# - GITHUB_REPOSITORY (provided by GitHub Actions)
#
# Required secrets in your target repository:
# - DISCORD_WEBHOOK
# - GEMINI_API_KEY
#
# No .env file needed in production repositories!