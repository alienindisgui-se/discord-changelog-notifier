# Credentials
DISCORD_WEBHOOK="https://discord.com/api/webhooks/your_webhook_url"
GEMINI_API_KEY="your_google_gemini_api_key"
GROQ_API_KEY="gsk_your_groq_api_key"
ASSEMBLYAI_API_KEY="your_assemblyai_api_key"
GITHUB_TOKEN="ghp_your_github_personal_access_token"

# Language Setting ('sv' or blank)
LANGUAGE="sv"

# Testing Controls: Set to 'mock', 'pr', or leave blank
TEST_MODE="mock"

# Logging Controls: Set to 'logs' or leave blank for default
LOG_DIR="logs"

# If TEST_MODE="pr", fill these in:
TEST_REPO="your-username/your-target-repo"
TEST_PR_NUMBER="12"